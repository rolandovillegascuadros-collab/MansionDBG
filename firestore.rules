rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isRoomPlayer(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId))
        && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerUids;
    }

    function isRoomInviteTarget() {
      return signedIn()
        && request.resource.data.toUid == request.auth.uid;
    }

    function isRoomInviteSender() {
      return signedIn()
        && request.resource.data.fromUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId)
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['friends', 'updatedAt'])
        );
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid)
        && request.resource.data.status in ['pending', 'accepted', 'rejected'];
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.playerUids;
      allow update: if signedIn()
        && (
          request.auth.uid in resource.data.playerUids
          || request.auth.uid in request.resource.data.playerUids
        );

      match /voiceConnections/{connectionId} {
        allow read, create, update: if isRoomPlayer(roomId);
      }

      match /chatMessages/{messageId} {
        allow read, create, update: if isRoomPlayer(roomId);
      }
    }

    match /roomInvitations/{inviteId} {
      allow read: if signedIn()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
      allow create: if isRoomInviteSender()
        && request.resource.data.toUid is string
        && request.resource.data.roomId is string
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid)
        && request.resource.data.status in ['pending', 'accepted', 'rejected'];
    }
  }
}
